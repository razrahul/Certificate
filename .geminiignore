# =========================================================================
# Antigravity & Gemini Agent Ignore Rules for Vite + React
# =========================================================================

# 1. Sensitive Data / Secrets (Most Important!)
# Gemini ko in files ko read ya touch karne se strictly rokne ke liye
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
secret_config.json

# 2. Heavy Dependencies & Build Outputs
# Isse agent confuse nahi hoga aur token space bachegi
node_modules/
dist/
build/
out/
.pnpm-store/

# 3. Heavy Lock Files (AI context noise reduction)
# Isse agents ko bade files scan karne se roka ja sakta hai
package-lock.json
yarn.lock
pnpm-lock.yaml

# 4. Logs and Diagnostics
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 5. IDE & System Files
.vscode/
.idea/
.DS_Store
Thumbs.db